{
  "name": "the-firehub-project/core-standard",
  "description": "The essential PHP core for clean, domain-driven architecture.",
  "type": "library",
  "keywords": ["php", "framework", "core", "firehub", "standard"],
  "homepage": "https://the-firehub-project.github.io/core-standard",
  "license": "Apache-2.0",
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "the-firehub-project/phpstan-rules": "dev-develop",

    "the-firehub-project/testing": "dev-develop"
  },
  "minimum-stability": "stable",
  "autoload": {
    "psr-4": {
      "FireHub\\Core\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FireHub\\Tests\\Core\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Danijel Galić",
      "email": "danijel.galic@outlook.com",
      "homepage": "https://github.com/dieselxxx",
      "role": "Owner"
    }
  ],
  "support": {
    "email": "danijel.galic@outlook.com",
    "issues": "https://github.com/The-FireHub-Project/Core-Standard/issues",
    "forum": "https://github.com/orgs/The-FireHub-Project/discussions",
    "wiki": "https://github.com/The-FireHub-Project/Core-Standard/wiki",
    "source": "https://github.com/The-FireHub-Project/Core-Standard",
    "docs": "https://the-firehub-project.github.io/Core-Standard",
    "security": "https://github.com/The-FireHub-Project/Core-Standard/security/policy"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/The-FireHub-Project"
    }
  ],
  "config": {
    "prepend-autoloader": false,
    "optimize-autoloader": true,
    "platform-check": true
  },
  "extra": {
    "firehub": {
      "layer": "core",
      "edition": "standard",
      "role": "foundation",
      "criticality": "critical"
    }
  }
}